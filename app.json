{
  "expo": {
    "name": "clashitoApp",
    "slug": "clashitoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoClashitoApp.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logoClashitoApp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gab0o06.clashitoApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logoClashitoApp.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoClashitoApp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aed84b78-72f5-4291-838c-4a213cf4a394"
      }
    }
  }
}
